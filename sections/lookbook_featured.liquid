

{% liquid
  assign selected_lookbook = section.settings.lookbook
  assign lookbook = shop.metaobjects['lookbook'][selected_lookbook]
%}


{% if lookbook != blank %}
<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} spacing-style {% if section.settings.color_scheme != blank %}color-{{ section.settings.color_scheme }}{% endif %}"
  style="{% render 'spacing-padding', settings: section.settings %}"
>
  {%- if lookbook != blank -%}
    {% capture lookbook_description %}
      {{ lookbook.description | metafield_tag }}
    {% endcapture %}
  {% render 'lookbook',
    title: lookbook.title.value,
    image: lookbook.image.value,
    description: lookbook_description,
    product_handles: lookbook.product_handles.value
  %}
  
  {%- endif -%}
</div>
{% endif %}

{% schema %}
{
  "name": "Lookbook",
    "disabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Select Lookbook"
    },
    {
      "type": "metaobject",
      "id": "lookbook",
      "label": "Lookbook",
      "metaobject_type": "lookbook"
    }
    

  ],
  "presets": [
    {
      "name": "Lookbook",
      "category": "t:categories.layout"
    }
  ]
}
{% endschema %}
